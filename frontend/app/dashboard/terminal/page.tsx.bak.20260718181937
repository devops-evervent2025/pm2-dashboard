"use client";

import { useEffect } from "react";
import { useRouter } from "next/navigation";
import { useAuth } from "@/lib/auth";
import Navbar from "@/components/Navbar";

export default function ServerTerminalPage() {
  const { role, isLoading } = useAuth();
  const router = useRouter();

  useEffect(() => {
    if (!isLoading && !role) {
      router.replace("/login");
    }
  }, [role, isLoading, router]);

  return (
    <div className="min-h-screen">
      <Navbar />
      <main className="max-w-6xl mx-auto px-4 py-8">
        <h1 className="text-2xl font-semibold text-slate-800 mb-2">Server Terminal</h1>
        <p className="text-sm text-slate-500 mb-6">
          A live terminal to your managed servers - being rebuilt.
        </p>
        <div className="card p-10 text-center text-slate-500">
          🚧 This page's previous content was corrupted (it contained placeholder text
          instead of real code) and has been temporarily replaced with this page so the
          rest of the dashboard builds and runs again. Let Claude know what this page
          should actually do and it'll be rebuilt properly.
        </div>
      </main>
    </div>
  );
}
