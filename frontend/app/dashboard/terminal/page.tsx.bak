"use client";

import { useEffect, useState, useCallback, useRef } from "react";
import { useRouter } from "next/navigation";
import { api, ClientItem, ServerItem, CurlCommandResult } from "@/lib/api";
import { useAuth } from "@/lib/auth";
import Navbar from "@/components/Navbar";

interface HistoryEntry {
  command: string;
  result?: CurlCommandResult;
  error?: string;
  running: boolean;
}

export default function TerminalPage() {
  const { role, isLoading } = useAuth();
  const router = useRouter();

  const [servers, setServers] = useState<(ServerItem & { clientName: string })[]>([]);
  const [loadingServers, setLoadingServers] = useState(true);
  const [serverId, setServerId] = useState<number | null>(null);

  const [input, setInput] = useState("curl ");
  const [history, setHistory] = useState<HistoryEntry[]>([]);
  const scrollRef = useRef<HTMLDivElement>(null);

  const fetchServers = useCallback(async () => {
    setLoadingServers(true);
    try {
      const clientsRes = await api.get<ClientItem[]>("/clients");
      const all: (ServerItem & { clientName: string })[] = [];
      for (const client of clientsRes.data) {
        const serversRes = await api.get<ServerItem[]>("/servers", {
          params: { client_id: client.id },
        });
        for (const s of serversRes.data) {
          all.push({ ...s, clientName: client.name });
        }
      }
      setServers(all);
      if (all.length > 0) setServerId((prev) => prev ?? all[0].id);
    } catch (err) {
      console.error(err);
    } finally {
      setLoadingServers(false);
    }
  }, []);

  useEffect(() => {
    if (!isLoading && !role) {
      router.replace("/login");
      return;
    }
    if (!isLoading && role && role !== "admin") {
      router.replace("/dashboard");
      return;
    }
    if (role === "admin") fetchServers();
  }, [role, isLoading, router, fetchServers]);

  useEffect(() => {
    scrollRef.current?.scrollTo({ top: scrollRef.current.scrollHeight });
  }, [history]);

  async function runCommand(e: React.FormEvent) {
    e.preventDefault();
    if (!serverId || !input.trim()) return;

    const command = input;
    setHistory((prev) => [...prev, { command, running: true }]);
    setInput("curl ");

    try {
      const res = await api.post<CurlCommandResult>(`/servers/${serverId}/terminal/curl`, {
        command,
      });
      setHistory((prev) => {
        const next = [...prev];
        next[next.length - 1] = { command, result: res.data, running: false };
        return next;
      });
    } catch (err: any) {
      setHistory((prev) => {
        const next = [...prev];
        next[next.length - 1] = {
          command,
          error: err?.response?.data?.detail || "Request failed",
          running: false,
        };
        return next;
      });
    }
  }

  if (role && role !== "admin") return null;

  const selectedServer = servers.find((s) => s.id === serverId);

  return (
    <div className="min-h-screen">
      <Navbar crumbs={[{ label: "Server Terminal" }]} />
      <main className="max-w-4xl mx-auto px-4 py-8">
        <div className="mb-6">
          <h1 className="text-2xl font-semibold text-slate-800">Server Terminal</h1>
          <p className="text-sm text-slate-500">
            Run <span className="font-mono">curl</span> commands against a managed server to test
            connectivity to internal services. Only <span className="font-mono">curl</span> is
            allowed — no other commands, chaining, or file redirection. Every command is logged.
          </p>
        </div>

        <div className="mb-4">
          <label className="block text-sm font-medium mb-1">Server</label>
          {loadingServers ? (
            <p className="text-sm text-slate-500">Loading servers…</p>
          ) : (
            <select
              className="input-field max-w-md"
              value={serverId ?? ""}
              onChange={(e) => setServerId(Number(e.target.value))}
            >
              {servers.map((s) => (
                <option key={s.id} value={s.id}>
                  {s.clientName} · {s.name} ({s.ip_address})
                </option>
              ))}
            </select>
          )}
        </div>

        <div className="card p-0 overflow-hidden flex flex-col h-[55vh]">
          <div className="px-4 py-2 border-b border-slate-200 bg-slate-50 text-xs text-slate-500">
            {selectedServer
              ? `Connected target: ${selectedServer.clientName} · ${selectedServer.name}`
              : "Select a server above"}
          </div>
          <div
            ref={scrollRef}
            className="flex-1 overflow-y-auto bg-slate-900 text-slate-100 font-mono text-xs p-4 space-y-3"
          >
            {history.length === 0 && (
              <p className="text-slate-500">
                Type a curl command below and press Enter. e.g.{" "}
                <span className="text-slate-300">curl http://localhost:8000/health</span>
              </p>
            )}
            {history.map((h, i) => (
              <div key={i}>
                <div className="text-emerald-400">$ {h.command}</div>
                {h.running && <div className="text-slate-500">running…</div>}
                {h.error && <div className="text-red-400 whitespace-pre-wrap">⚠ {h.error}</div>}
                {h.result && (
                  <>
                    {h.result.stdout && (
                      <div className="whitespace-pre-wrap break-all">{h.result.stdout}</div>
                    )}
                    {h.result.stderr && (
                      <div className="whitespace-pre-wrap break-all text-amber-400">
                        {h.result.stderr}
                      </div>
                    )}
                    <div className="text-slate-500">
                      exit status: {h.result.exit_status ?? "unknown"}
                    </div>
                  </>
                )}
              </div>
            ))}
          </div>
          <form onSubmit={runCommand} className="border-t border-slate-200 p-3 flex gap-2">
            <input
              className="input-field font-mono text-sm"
              value={input}
              onChange={(e) => setInput(e.target.value)}
              placeholder="curl http://localhost:8000/health"
              disabled={!serverId}
              autoComplete="off"
              spellCheck={false}
            />
            <button type="submit" className="btn-primary text-sm" disabled={!serverId}>
              Run
            </button>
          </form>
        </div>
      </main>
    </div>
  );
}
