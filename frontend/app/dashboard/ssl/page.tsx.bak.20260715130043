"use client";

import { useEffect, useState, useCallback } from "react";
import { useRouter } from "next/navigation";
import { api } from "@/lib/api";
import { useAuth } from "@/lib/auth";
import Navbar from "@/components/Navbar";
import AddSSLServerModal from "@/components/AddSSLServerModal";

interface SSLDomainItem {
  id: number;
  name: string;
  ip_address: string;
  config_path: string;
  threshold_days: number;
  domain_name?: string | null;
  expiry_date?: string | null;
  days_remaining?: number | null;
  last_checked_at?: string | null;
  last_check_error?: string | null;
  status: "ok" | "warning" | "critical" | "expired" | "unknown";
}

const STATUS_STYLES: Record<string, string> = {
  ok: "bg-emerald-100 text-emerald-700",
  warning: "bg-amber-100 text-amber-700",
  critical: "bg-orange-100 text-orange-700",
  expired: "bg-red-100 text-red-700",
  unknown: "bg-slate-200 text-slate-600",
};

const STATUS_LABELS: Record<string, string> = {
  ok: "OK",
  warning: "Warning",
  critical: "Critical",
  expired: "Expired",
  unknown: "Not checked yet",
};

function daysLabel(item: SSLDomainItem): string {
  if (item.days_remaining === null || item.days_remaining === undefined) return "—";
  if (item.days_remaining < 0) return `Expired ${Math.abs(item.days_remaining)} days ago`;
  if (item.days_remaining === 0) return "Expires today";
  return `${item.days_remaining} days left`;
}

export default function SSLDashboardPage() {
  const { role, isLoading } = useAuth();
  const router = useRouter();
  const [items, setItems] = useState<SSLDomainItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [showAddModal, setShowAddModal] = useState(false);
  const [checkingAll, setCheckingAll] = useState(false);
  const [checkingId, setCheckingId] = useState<number | null>(null);

  const fetchItems = useCallback(async () => {
    setLoading(true);
    try {
      const res = await api.get<SSLDomainItem[]>("/ssl");
      setItems(res.data);
      setError(null);
    } catch (err) {
      setError("SSL entries load नहीं हो सकीं");
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    if (!isLoading && !role) {
      router.replace("/login");
      return;
    }
    if (role) fetchItems();
  }, [role, isLoading, router, fetchItems]);

  async function checkOne(id: number) {
    setCheckingId(id);
    try {
      await api.post(`/ssl/${id}/check`);
      await fetchItems();
    } catch {
      // error शो हो जाएगा agli list refresh पर last_check_error field से
    } finally {
      setCheckingId(null);
    }
  }

  async function refreshAll() {
    setCheckingAll(true);
    try {
      await Promise.all(items.map((item) => api.post(`/ssl/${item.id}/check`).catch(() => null)));
      await fetchItems();
    } finally {
      setCheckingAll(false);
    }
  }

  async function handleDelete(id: number) {
    if (!confirm("यह SSL entry हटा दें?")) return;
    await api.delete(`/ssl/${id}`);
    fetchItems();
  }

  return (
    <div className="min-h-screen">
      <Navbar />
      <main className="max-w-6xl mx-auto px-4 py-8">
        <div className="flex items-center justify-between mb-6">
          <div>
            <h1 className="text-2xl font-semibold text-slate-800">SSL Dashboard</h1>
            <p className="text-sm text-slate-500">
              हर server के certificate की expiry track कीजिए
            </p>
          </div>
          <div className="flex gap-2">
            <button
              className="btn-secondary"
              onClick={refreshAll}
              disabled={checkingAll || items.length === 0}
            >
              {checkingAll ? "Checking…" : "Refresh all"}
            </button>
            {role === "admin" && (
              <button className="btn-primary" onClick={() => setShowAddModal(true)}>
                + Add Server
              </button>
            )}
          </div>
        </div>

        {loading && <p className="text-slate-500">Loading…</p>}
        {error && <p className="text-red-600">{error}</p>}
        {!loading && items.length === 0 && (
          <div className="card p-10 text-center text-slate-500">
            अभी कोई SSL entry नहीं है। "+ Add Server" दबाकर पहली entry जोड़िए।
          </div>
        )}

        <div className="space-y-3">
          {items.map((item) => (
            <div key={item.id} className="card p-4 flex items-center justify-between gap-4">
              <div className="min-w-0">
                <div className="flex items-center gap-2 flex-wrap">
                  <span className="font-medium text-slate-800">{item.name}</span>
                  {item.domain_name && (
                    <span className="text-xs text-slate-400">({item.domain_name})</span>
                  )}
                  <span className={`badge ${STATUS_STYLES[item.status]}`}>
                    {STATUS_LABELS[item.status]}
                  </span>
                </div>
                <p className="text-xs text-slate-500 mt-1">
                  {item.ip_address} · {item.config_path}
                </p>
                <p className="text-sm mt-1">
                  {daysLabel(item)}
                  {item.expiry_date && (
                    <span className="text-slate-400">
                      {" "}
                      · expires {new Date(item.expiry_date).toLocaleDateString()}
                    </span>
                  )}
                </p>
                {item.last_check_error && (
                  <p className="text-xs text-red-600 mt-1">⚠ {item.last_check_error}</p>
                )}
              </div>
              <div className="flex items-center gap-2 shrink-0">
                <button
                  className="btn-secondary text-xs"
                  onClick={() => checkOne(item.id)}
                  disabled={checkingId === item.id}
                >
                  {checkingId === item.id ? "Checking…" : "Check now"}
                </button>
                {role === "admin" && (
                  <button
                    className="btn-secondary text-xs text-red-600"
                    onClick={() => handleDelete(item.id)}
                  >
                    Delete
                  </button>
                )}
              </div>
            </div>
          ))}
        </div>
      </main>
      {showAddModal && (
        <AddSSLServerModal onClose={() => setShowAddModal(false)} onCreated={fetchItems} />
      )}
    </div>
  );
}
