import datetime
from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session

from app.database import get_db
from app.auth import get_current_user, require_admin
from app.ssl_models import SSLDomain
from app.ssl_schemas import SSLDomainCreate, SSLDomainOut
from app.ssl_manager import check_certificate, SSLCheckError

router = APIRouter(prefix="/ssl", tags=["ssl"])


def _compute_status(domain: SSLDomain) -> str:
    if domain.last_check_error:
        return "unknown"
    if domain.days_remaining is None:
        return "unknown"
    if domain.days_remaining < 0:
        return "expired"
    if domain.days_remaining <= domain.threshold_days:
        return "critical"
    if domain.days_remaining <= domain.threshold_days * 2:
        return "warning"
    return "ok"


def _to_out(domain: SSLDomain) -> SSLDomainOut:
    return SSLDomainOut(
        id=domain.id,
        name=domain.name,
        ip_address=domain.ip_address,
        config_path=domain.config_path,
        threshold_days=domain.threshold_days,
        domain_name=domain.domain_name,
        expiry_date=domain.expiry_date,
        days_remaining=domain.days_remaining,
        last_checked_at=domain.last_checked_at,
        last_check_error=domain.last_check_error,
        status=_compute_status(domain),
    )


@router.get("", response_model=list[SSLDomainOut])
def list_ssl_domains(db: Session = Depends(get_db), _user=Depends(get_current_user)):
    return [_to_out(d) for d in db.query(SSLDomain).all()]


@router.post("", response_model=SSLDomainOut)
def create_ssl_domain(payload: SSLDomainCreate, db: Session = Depends(get_db), _admin=Depends(require_admin)):
    domain = SSLDomain(**payload.model_dump())
    db.add(domain)
    db.commit()
    db.refresh(domain)
    return _to_out(domain)


@router.delete("/{domain_id}")
def delete_ssl_domain(domain_id: int, db: Session = Depends(get_db), _admin=Depends(require_admin)):
    domain = db.query(SSLDomain).filter(SSLDomain.id == domain_id).first()
    if not domain:
        raise HTTPException(status_code=404, detail="Not found")
    db.delete(domain)
    db.commit()
    return {"detail": "deleted"}


@router.post("/{domain_id}/check", response_model=SSLDomainOut)
def check_ssl_domain(domain_id: int, db: Session = Depends(get_db), _user=Depends(get_current_user)):
    domain = db.query(SSLDomain).filter(SSLDomain.id == domain_id).first()
    if not domain:
        raise HTTPException(status_code=404, detail="Not found")
    try:
        result = check_certificate(domain)
        domain.domain_name = result["domain_name"]
        domain.expiry_date = result["expiry_date"]
        domain.days_remaining = result["days_remaining"]
        domain.last_check_error = None
    except SSLCheckError as exc:
        domain.last_check_error = str(exc)
    domain.last_checked_at = datetime.datetime.utcnow()
    db.commit()
    db.refresh(domain)
    return _to_out(domain)
