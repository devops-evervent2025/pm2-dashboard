# ---- App ----
APP_NAME=PM2 Dashboard
ENVIRONMENT=Prod                 # Dev / Prod / Stg -> free text, anything else shows as "Other"
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000

# ---- MySQL Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=pm2dash
DB_PASSWORD=Ankit@261,
DB_NAME=pm2_dashboard

# ---- Default admin (created on first init_db run) ----
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-immediately
DEFAULT_ADMIN_EMAIL=admin@example.com

# ---- SSH defaults (can be overridden per-server in the UI) ----
SSH_DEFAULT_PORT=22
SSH_DEFAULT_USERNAME=root
SSH_CONNECT_TIMEOUT=10
# Only ONE of these is required per server (set on the server record):
#  - password
#  - private key path on the backend host
SSH_PRIVATE_KEY_PATH=
